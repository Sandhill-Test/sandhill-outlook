{
  "tags": {
    "allowUnknownTags": false
  },
  "source": {
    "include": ["src", "../js"],
    "includePattern": "\\.js$",
    "excludePattern": "(node_modules/|docs)"
  },
  "plugins": ["plugins/markdown"],
  "opts": {
    "template": "node_modules/docdash",

    "encoding": "utf8",
    "destination": "docs/",
    "recurse": true,
    "verbose": true
  },
  "templates": {
    "cleverLinks": false,
    "monospaceLinks": false
  },

  "docdash": {
    "sort": [true],

    "search": [true],
    "collapse": [true],
    "wrap": [true],
    "typedefs": [true],
    "navLevel": [1],
    "scripts": []
  }
}
